# Server Configuration
PORT=8080
NODE_ENV=production

# MongoDB Atlas
# Replace with your production MongoDB connection string
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/bharatonestop

# JWT Authentication
# Generate strong 64-character hex strings for these in production
JWT_SECRET=your_production_jwt_secret_key
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your_production_refresh_secret_key
JWT_REFRESH_EXPIRES_IN=7d

# Gemini AI Integration (Current Path)
# Replace with your active Gemini API key
GEMINI_API_KEY=your_production_gemini_api_key
GEMINI_MODEL=gemini-flash-lite-latest

# Google Cloud Project Configuration
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GCS_BUCKET_NAME=your-gcp-storage-bucket-name
CLIENT_ORIGIN=https://your-firebase-hosted-app.web.app
